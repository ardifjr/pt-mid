							<a id="menu_close" class="menu-close" href="javascript:void(0);"> <i class="fas fa-times"></i></a>
						</div>
						<ul class="main-nav">
							<li class="has-submenu">
								<a href="/">Beranda</a>
							</li>
							<li class="has-submenu">
								<a href="javascript:void(0);">Perusahaan <i class="fas fa-chevron-down"></i></a>
								<ul class="submenu">
									<!-- <li class="active"><a href="/">Home 1</a></li> -->
									<li><a href="/about-us">Tentang Kami</a></li> <!-- inc identitas, visi misi, struktur organisasi, legalitas --> 
									<li><a href="/portofolio">Portofolio</a></li> <!-- inc on going / out going -->
								</ul>
							</li>
							<li><a href="/layanan">Layanan</a></li>
							<li><a href="/artikel">Artikel</a></li>
							<li><a href="/karir">Karir</a></li>
						</ul>
					</div>
					<ul class="nav header-navbar-rht">
						<li class="nav-item">
						</li>
						<li class="nav-item">
						</li>
					</ul>
					<ul class="nav header-navbar-rht">
						<li class="nav-item">
							<a class="nav-link header-reg" href="/contact">Kontak</a>
						</li>
						<li class="nav-item">
							<a class="nav-link header-login" href="/technoplexLiving">Technoplex Living Bandung</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>
		<!-- /Header -->

    <!-- Konten halaman akan masuk di sini -->
    <slot />

   <!-- Footer -->
		<footer class="footer">
			<!-- Footer Top -->
			<div class="footer-top aos" data-aos="fade-up">
				<div class="container">
					<div class="row">
						<div class="col-lg-4 col-md-6">
							<!-- Footer Widget -->
							<div class="footer-widget">
								<div class="footer-logo">
									<a href="/"><img src="/assets/img/logo.png" alt="logo"></a>
								</div>
								<div class="footer-content">
