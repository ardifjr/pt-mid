									<p class="mb-0">
									Copyright &copy; {new Date().getFullYear()}. All Rights Reserved.
									</p>
								</div>
							</div>
							<div class="col-md-4">
								<div class="payment-image">
									<ul>
										
									</ul>
								</div>
							</div>
							<div class="col-md-4">
								<!-- Copyright Menu -->
								<div class="copyright-menu">
								</div>
								<!-- /Copyright Menu -->
							</div>
						</div>
					</div>
					<!-- /Copyright -->
				</div>
			</div>
			<!-- /Footer Bottom -->
			
		</footer>
