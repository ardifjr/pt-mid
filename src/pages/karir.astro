---
import MainLayout from '../layouts/MainLayout.astro';
import karirData from '../data/karir.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="astro-view-transitions" />
    <title>PT Multyartha Indo Daya</title>
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
	<link rel="stylesheet" href="/assets/css/feather.css">
    <!-- CSS dari public -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
 <body>

	
	<div class="main-wrapper">
	<MainLayout title="Karir">
	<!-- Breadcrumb -->
		<div class="breadcrumb-bar">
			<div class="container">
				<div class="row">
					<div class="col-md-12 col-12">
						<h2 class="breadcrumb-title">Karir</h2>
					</div>
				</div>
			</div>
		</div>
		<!-- /Breadcrumb -->
		
		<div class="content">
			<div class="container">
				<div class="row">
					<div class="col-12">
						
						<div class="row">
					
							{karirData.map((item) => (
								<div class="col-md-4 d-flex">
									<!-- Blog Post -->
									<div class="blog grid-blog flex-fill">
										<div class="blog-image">
											<a href="#"
												class="detail-btn"
												data-img={item.img}
												data-judul={item.judul_lamaran}
												data-posisi={item.posisi_lamaran}
												data-tanggal={item.tanggal_dibuat}
												data-deskripsi={item.deskripsi}
												style="cursor:pointer;">
												<img class="img-fluid" src={item.img} alt={item.judul_lamaran} />
											</a>
										</div>
										<div class="blog-content">
											<div class="blog-category">
												<ul>
													<li><span class="cat-blog">{item.posisi_lamaran}</span></li>
													<li><i class="feather-calendar me-2"></i>{item.tanggal_dibuat}</li>
												</ul>
											</div>
											<h3 class="blog-title">
												<a href="#"
													class="detail-btn"
													data-img={item.img}
													data-judul={item.judul_lamaran}
													data-posisi={item.posisi_lamaran}
													data-tanggal={item.tanggal_dibuat}
													data-deskripsi={item.deskripsi}
													style="cursor:pointer;">
													{item.judul_lamaran}
												</a>
											</h3>
											<div class="paragraf">
												<p class="paragraf-text">{item.deskripsi}</p>
											</div>
											<div class="blog-buttons mt-auto"> 
												<a href="#" class="read-more detail-btn"
													data-img={item.img}
													data-judul={item.judul_lamaran}
													data-posisi={item.posisi_lamaran}
													data-tanggal={item.tanggal_dibuat}
													data-deskripsi={item.deskripsi}>Detail</a> 
												<a href="#form-lamaran" class="apply-btn" data-posisi={item.posisi_lamaran}>Lamar Sekarang</a> 
											</div>
										</div>
									</div>
									<!-- /Blog Post -->
								</div>
							))}

							<!-- Detail Modal -->
							<div id="detailModal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.55); backdrop-filter:blur(3px); align-items:center; justify-content:center;">
								<div style="background:#fff; border-radius:16px; max-width:560px; width:90%; max-height:85vh; overflow-y:auto; padding:0; box-shadow:0 20px 60px rgba(0,0,0,0.3); position:relative;">
									<button id="closeModal" style="position:sticky; top:12px; float:right; margin:12px 12px 0 0; background:#f0f0f0; border:none; border-radius:50%; width:36px; height:36px; font-size:18px; cursor:pointer; line-height:36px; text-align:center; z-index:10;">&times;</button>
									<img id="modal-img" src="" alt="" style="width:100%; height:220px; object-fit:cover; border-radius:16px 16px 0 0; display:block;">
									<div style="padding:24px 28px 28px;">
										<span id="modal-posisi" style="background:#e8f0fe; color:#1a56db; font-size:0.8rem; font-weight:600; padding:4px 12px; border-radius:20px;"></span>
										<p id="modal-tanggal" style="color:#888; font-size:0.82rem; margin-top:10px;"><i class="feather-calendar" style="margin-right:5px;"></i><span></span></p>
										<h4 id="modal-judul" style="font-size:1.2rem; font-weight:700; margin:10px 0 14px; color:#1a1a2e;"></h4>
										<p id="modal-deskripsi" style="color:#555; font-size:0.92rem; line-height:1.7; white-space:pre-line;"></p>
										<a id="modal-apply-btn" href="#form-lamaran" class="btn btn-primary mt-3" style="width:100%; text-align:center;">Lamar Sekarang</a>
									</div>
								</div>
							</div>
							<!-- /Detail Modal -->
														
							<!-- Get In Touch -->
							<div class="contact-queries" id="form-lamaran" style="padding-top:15px;">
							<h2>Kirim Lamaran Anda</h2>
							<form id="lamaranForm" novalidate>
								<div class="row">
								<div class="col-md-4">
									<div class="form-group">
									<label class="col-form-label">Posisi Yang Di Lamar</label>
									<div class="form-icon">
										<input id="posisi" class="form-control" type="text" placeholder="Pilih Lamaran di Atas" readonly>
									</div>
									</div>
								</div>
								</div>
								<div class="row">
								<div class="col-md-4">
									<div class="form-group">
									<label class="col-form-label">Nama</label>
									<div class="form-icon">
										<input id="nama" class="form-control" type="text" placeholder="Masukkan Nama Lengkap">
										<span class="cus-icon"><i class="feather-user"></i></span>
									</div>
									<span class="error-msg" id="err_nama"></span>
									</div>
								</div>
								<div class="col-md-4">
									<div class="form-group">
									<label class="col-form-label">Email</label>
									<div class="form-icon">
										<input id="email" class="form-control" type="email" placeholder="Masukkan Alamat Email">
										<span class="cus-icon"><i class="feather-mail"></i></span>
									</div>
									<span class="error-msg" id="err_email"></span>
									</div>
								</div>
								<div class="col-md-4">
									<div class="form-group">
									<label class="col-form-label">Nomor Telepon Aktif</label>
									<div class="form-icon">
										<input id="telepon" class="form-control" type="text" placeholder="Masukkan Nomor Telepon">
										<span class="cus-icon"><i class="feather-phone"></i></span>
									</div>
									<span class="error-msg" id="err_telepon"></span>
									</div>
								</div>
								<div class="col-md-12">
									<div class="form-group">
									<label class="col-form-label">Alamat Lengkap</label>
									<div class="form-icon form-msg">
										<textarea id="alamat" class="form-control" rows="4" placeholder="Masukkan Alamat Lengkap"></textarea>
									</div>
									<span class="error-msg" id="err_alamat"></span>
									</div>
								</div>

								<!-- Upload CV -->
								<div class="col-lg-6">
									<div class="form-group">
									<label class="col-form-label">Curriculum Vitae <small class="text-muted">(PDF)</small></label>
									</div>
									<div class="upload-box" id="box_cv">
									<input type="file" id="cvUpload" class="upload-input" accept=".pdf">
									<label for="cvUpload" class="upload-label">
										<img src="/assets/img/icons/upload.svg" alt="upload">
										<h6>Sematkan File Atau <span>Browse</span></h6>
										<p>Supported format: PDF</p>
										<p>Maksimal 10MB</p>
									</label>
									</div>
									<span class="upload-filename" id="filename_cv"></span>
									<span class="error-msg" id="err_cv"></span>
								</div>

								<!-- Upload Surat Lamaran -->
								<div class="col-lg-6">
									<div class="form-group">
									<label class="col-form-label">Surat Lamaran <small class="text-muted">(JPEG / PNG)</small></label>
									</div>
									<div class="upload-box" id="box_surat">
									<input type="file" id="suratUpload" class="upload-input" accept=".jpg,.jpeg,.png">
									<label for="suratUpload" class="upload-label">
										<img src="/assets/img/icons/upload.svg" alt="upload">
										<h6>Sematkan Gambar Atau <span>Browse</span></h6>
										<p>Supported formats: JPEG, PNG</p>
										<p>Maksimal 10MB</p>
									</label>
									</div>
									<span class="upload-filename" id="filename_surat"></span>
									<span class="error-msg" id="err_surat"></span>
								</div>

								<div class="col-md-12 text-left mt-3">
									<button id="submitBtn" class="btn btn-primary" type="submit">
									<span id="btn-text">Kirim Lamaran</span>
									<span id="btn-loading" class="d-none">Mengirim...</span>
									</button>
								</div>
								</div>
							</form>
							</div>
							<!-- /Get In Touch -->
						</div>
					</div>
				</div>
			</div>	
		
			<!-- Cursor -->
			<div class="mouse-cursor cursor-outer"></div>
			<div class="mouse-cursor cursor-inner"></div>
			<!-- /Cursor -->	
			
		</div>		
	</MainLayout>
	</div>
	
	<style>
		.blog-content .blog-title,
		.grid-blog .blog-content .blog-title {
			display: block;
			-webkit-line-clamp: unset;
			overflow: visible;
		}

		.blog.grid-blog {
			display: flex;
			flex-direction: column;
		}

		.blog-content {
			display: flex;
			flex-direction: column;
			flex: 1;
		}

		.blog-content .paragraf {
			flex: 1;
		}
	
		html {
			scroll-behavior: smooth;
		}

		.error-msg {
			display: none;
			color: #dc3545;
			font-size: 0.813rem;
			margin-top: 4px;
		}

		.form-control.is-invalid,
		.form-control.is-valid {
			background-image: none !important;
			padding-right: 0.75rem !important;
		}

		.form-control.is-invalid {
			border-color: #dc3545;
		}

		.form-control.is-valid {
			border-color: #198754;
		}

		.upload-box.is-invalid {
			border: 2px dashed #dc3545 !important;
		}

		.upload-box.is-valid {
			border: 2px dashed #198754 !important;
		}

		.upload-filename {
			font-size: 0.813rem;
			color: #198754;
			margin-top: 4px;
			display: none;
		}
	</style>

	<script>
	import emailjs from '@emailjs/browser';
	import Swal from 'sweetalert2';

	const EMAILJS_PUBLIC_KEY  = "1QUcVHgo-Cl5uvfpy";
	const EMAILJS_SERVICE_ID  = "service_aq76qvx";
	const EMAILJS_TEMPLATE_ID = "template_vzs28hi";
	const CLOUDINARY_CLOUD_NAME    = "dm1mhlpy1";
	const CLOUDINARY_UPLOAD_PRESET = "lamaran_preset";

	emailjs.init(EMAILJS_PUBLIC_KEY);

	// ── Cloudinary Upload ─────────────────────────────────
	async function uploadToCloudinary(file: File): Promise<string> {
		const formData = new FormData();
		formData.append("file", file);
		formData.append("upload_preset", CLOUDINARY_UPLOAD_PRESET);
		const resourceType = file.type === "application/pdf" ? "raw" : "image";
		const res = await fetch(
			`https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD_NAME}/${resourceType}/upload`,
			{ method: "POST", body: formData }
		);
		if (!res.ok) {
			const errData = await res.json();
			throw new Error(errData?.error?.message ?? "Gagal upload ke Cloudinary");
		}
		const data = await res.json();
		return data.secure_url as string;
	}

	const form       = document.getElementById("lamaranForm") as HTMLFormElement;
	const submitBtn  = document.getElementById("submitBtn")   as HTMLButtonElement;
	const btnText    = document.getElementById("btn-text")!;
	const btnLoading = document.getElementById("btn-loading")!;

	// ── Detail Modal ──────────────────────────────────────
	const modal      = document.getElementById("detailModal")!;
	const closeModal = document.getElementById("closeModal")!;

	document.querySelectorAll(".detail-btn").forEach((btn) => {
		btn.addEventListener("click", function (e) {
			e.preventDefault();
			const el = this as HTMLElement;
			(document.getElementById("modal-img") as HTMLImageElement).src = el.dataset.img ?? "";
			(document.getElementById("modal-img") as HTMLImageElement).alt = el.dataset.judul ?? "";
			document.getElementById("modal-posisi")!.textContent = el.dataset.posisi ?? "";
			document.querySelector("#modal-tanggal span")!.textContent = el.dataset.tanggal ?? "";
			document.getElementById("modal-judul")!.textContent = el.dataset.judul ?? "";
			document.getElementById("modal-deskripsi")!.textContent = el.dataset.deskripsi ?? "";

			// Set posisi on modal apply button click
			const applyBtn = document.getElementById("modal-apply-btn")!;
			applyBtn.setAttribute("data-posisi", el.dataset.posisi ?? "");

			modal.style.display = "flex";
			document.body.style.overflow = "hidden";
		});
	});

	// Close modal apply btn → fill form & close modal
	document.getElementById("modal-apply-btn")!.addEventListener("click", function () {
		const posisi = (this as HTMLElement).getAttribute("data-posisi") ?? "";
		(document.getElementById("posisi") as HTMLInputElement).value = posisi;
		modal.style.display = "none";
		document.body.style.overflow = "";
	});

	closeModal.addEventListener("click", () => {
		modal.style.display = "none";
		document.body.style.overflow = "";
	});

	modal.addEventListener("click", function (e) {
		if (e.target === modal) {
			modal.style.display = "none";
			document.body.style.overflow = "";
		}
	});

	// ── Tombol "Lamar Sekarang" di card ───────────────────
	document.querySelectorAll(".apply-btn").forEach((btn) => {
		btn.addEventListener("click", function () {
			const posisi = (this as HTMLElement).getAttribute("data-posisi") ?? "";
			(document.getElementById("posisi") as HTMLInputElement).value = posisi;
		});
	});

	// ── Validasi helpers ──────────────────────────────────
	function showError(inputId: string, errId: string, msg: string) {
		const el = document.getElementById(inputId) as HTMLElement | null;
		if (el) { el.classList.add("is-invalid"); el.classList.remove("is-valid"); }
		const err = document.getElementById(errId)!;
		err.textContent = msg;
		err.style.display = "block";
	}

	function clearError(inputId: string, errId: string) {
		const el = document.getElementById(inputId) as HTMLElement | null;
		if (el) { el.classList.remove("is-invalid"); el.classList.add("is-valid"); }
		document.getElementById(errId)!.style.display = "none";
	}

	function showUploadError(boxId: string, errId: string, msg: string) {
		const box = document.getElementById(boxId)!;
		box.classList.add("is-invalid"); box.classList.remove("is-valid");
		const err = document.getElementById(errId)!;
		err.textContent = msg; err.style.display = "block";
	}

	function clearUploadError(boxId: string, errId: string, filenameId: string, filename: string) {
		const box = document.getElementById(boxId)!;
		box.classList.remove("is-invalid"); box.classList.add("is-valid");
		document.getElementById(errId)!.style.display = "none";
		const fn = document.getElementById(filenameId)!;
		fn.textContent = filename; fn.style.display = "block";
	}

	// ── Real-time validation ──────────────────────────────
	document.getElementById("nama")!.addEventListener("input", function () {
		(this as HTMLInputElement).value.trim()
			? clearError("nama", "err_nama")
			: showError("nama", "err_nama", "Nama tidak boleh kosong.");
	});

	document.getElementById("email")!.addEventListener("input", function () {
		const val = (this as HTMLInputElement).value.trim();
		const re  = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
		if (!val)               showError("email", "err_email", "Email tidak boleh kosong.");
		else if (!re.test(val)) showError("email", "err_email", "Format email tidak valid.");
		else                    clearError("email", "err_email");
	});

	document.getElementById("telepon")!.addEventListener("input", function () {
		const val = (this as HTMLInputElement).value.trim();
		if (!val)                                  showError("telepon", "err_telepon", "Nomor telepon tidak boleh kosong.");
		else if (!/^[0-9+\-\s]{8,15}$/.test(val)) showError("telepon", "err_telepon", "Format nomor telepon tidak valid.");
		else                                       clearError("telepon", "err_telepon");
	});

	document.getElementById("alamat")!.addEventListener("input", function () {
		(this as HTMLTextAreaElement).value.trim()
			? clearError("alamat", "err_alamat")
			: showError("alamat", "err_alamat", "Alamat tidak boleh kosong.");
	});

	document.getElementById("cvUpload")!.addEventListener("change", function () {
		const file = (this as HTMLInputElement).files?.[0];
		if (!file) return;
		file.type === "application/pdf"
			? clearUploadError("box_cv", "err_cv", "filename_cv", file.name)
			: showUploadError("box_cv", "err_cv", "CV harus dalam format PDF.");
	});

	document.getElementById("suratUpload")!.addEventListener("change", function () {
		const file = (this as HTMLInputElement).files?.[0];
		if (!file) return;
		["image/jpeg", "image/png"].includes(file.type)
			? clearUploadError("box_surat", "err_surat", "filename_surat", file.name)
			: showUploadError("box_surat", "err_surat", "Surat lamaran harus JPEG atau PNG.");
	});

	// ── Submit ────────────────────────────────────────────
	form.addEventListener("submit", async function (e) {
		e.preventDefault();

		const nama      = (document.getElementById("nama")        as HTMLInputElement).value.trim();
		const email     = (document.getElementById("email")       as HTMLInputElement).value.trim();
		const telepon   = (document.getElementById("telepon")     as HTMLInputElement).value.trim();
		const alamat    = (document.getElementById("alamat")      as HTMLTextAreaElement).value.trim();
		const posisi    = (document.getElementById("posisi")      as HTMLInputElement).value.trim();
		const cvFile    = (document.getElementById("cvUpload")    as HTMLInputElement).files?.[0];
		const suratFile = (document.getElementById("suratUpload") as HTMLInputElement).files?.[0];
		const emailRe   = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

		let valid = true;

		if (!nama)   { showError("nama",  "err_nama",  "Nama tidak boleh kosong.");  valid = false; }
		else           clearError("nama",  "err_nama");

		if (!email)                    { showError("email", "err_email", "Email tidak boleh kosong.");   valid = false; }
		else if (!emailRe.test(email)) { showError("email", "err_email", "Format email tidak valid.");   valid = false; }
		else                             clearError("email", "err_email");

		if (!telepon)                                  { showError("telepon", "err_telepon", "Nomor telepon tidak boleh kosong."); valid = false; }
		else if (!/^[0-9+\-\s]{8,15}$/.test(telepon)) { showError("telepon", "err_telepon", "Format nomor telepon tidak valid."); valid = false; }
		else                                             clearError("telepon", "err_telepon");

		if (!alamat) { showError("alamat", "err_alamat", "Alamat tidak boleh kosong."); valid = false; }
		else           clearError("alamat", "err_alamat");

		if (cvFile && cvFile.type !== "application/pdf") {
			showUploadError("box_cv", "err_cv", "CV harus dalam format PDF.");
			valid = false;
		}

		if (suratFile && !["image/jpeg","image/png"].includes(suratFile.type)) {
			showUploadError("box_surat", "err_surat", "Surat lamaran harus JPEG atau PNG.");
			valid = false;
		}

		if (!valid) return;

		submitBtn.disabled = true;
		btnText.classList.add("d-none");
		btnLoading.classList.remove("d-none");

		try {
			let cv_url    = "(tidak dilampirkan)";
			let surat_url = "(tidak dilampirkan)";

			if (cvFile) {
				Swal.fire({ title: "Mengupload CV...", text: "Mohon tunggu sebentar", allowOutsideClick: false, allowEscapeKey: false, didOpen: () => Swal.showLoading() });
				cv_url = await uploadToCloudinary(cvFile);
			}

			if (suratFile) {
				Swal.fire({ title: "Mengupload Surat Lamaran...", text: "Mohon tunggu sebentar", allowOutsideClick: false, allowEscapeKey: false, didOpen: () => Swal.showLoading() });
				surat_url = await uploadToCloudinary(suratFile);
			}

			Swal.fire({ title: "Mengirim lamaran...", text: "Mohon tunggu sebentar", allowOutsideClick: false, allowEscapeKey: false, didOpen: () => Swal.showLoading() });

			await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, {
				posisi, nama, email, telepon, alamat,
				cv_name   : cvFile?.name    ?? "(tidak dilampirkan)",
				cv_url,
				surat_name: suratFile?.name ?? "(tidak dilampirkan)",
				surat_url,
			});

			Swal.fire({
				icon: "success",
				title: "Lamaran Terkirim!",
				text: "Terima kasih telah melamar. Kami akan menghubungi kamu segera.",
				confirmButtonText: "Oke",
				confirmButtonColor: "#0d6efd",
			});

			form.reset();
			["nama", "email", "telepon", "alamat"].forEach(id =>
				document.getElementById(id)!.classList.remove("is-valid", "is-invalid")
			);
			["box_cv", "box_surat"].forEach(id =>
				document.getElementById(id)!.classList.remove("is-valid", "is-invalid")
			);
			["filename_cv", "filename_surat"].forEach(id => {
				const el = document.getElementById(id)!;
				el.textContent   = "";
				el.style.display = "none";
			});

		} catch (err) {
			console.error(err);
			Swal.fire({
				icon: "error",
				title: "Gagal Mengirim!",
				text: "Terjadi kesalahan saat mengirim lamaran. Silakan coba lagi.",
				confirmButtonText: "Coba Lagi",
				confirmButtonColor: "#dc3545",
			});
		} finally {
			btnText.classList.remove("d-none");
			btnLoading.classList.add("d-none");
			submitBtn.disabled = false;
		}
	});
	</script>

	<style>
		.paragraf-text {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	</style>
	
	<!-- jQuery -->
