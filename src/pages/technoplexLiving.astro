	<!-- Modal Tipe Unit -->
	<div id="unit-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);align-items:center;justify-content:center;">
	<div style="background:#fff;border-radius:16px;max-width:560px;width:90%;max-height:90vh;overflow-y:auto;padding:32px;position:relative;box-shadow:0 24px 60px rgba(0,0,0,0.25);">
		<button id="modal-close" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:28px;cursor:pointer;color:#333;line-height:1;">&times;</button>
		<div id="modal-detail-img" style="margin-bottom:20px;"></div>
		<h3 id="modal-title" style="margin-bottom:6px;font-size:22px;font-weight:700;color:#1a1a1a;"></h3>
		<p id="modal-luas" style="margin-bottom:12px;color:#666;font-size:15px;"></p>
		<p id="modal-desc" style="color:#444;font-size:15px;line-height:1.7;margin-bottom:24px;"></p>
		<a id="modal-wa-btn" href="" target="_blank" style="display:inline-block;background:#25D366;color:#fff;padding:12px 28px;border-radius:8px;text-decoration:none;font-weight:600;font-size:15px;">
		<i class="fab fa-whatsapp" style="margin-right:8px;"></i>Hubungi Kami
		</a>
	</div>
	</div>

	<script is:inline>
	const WA_NUMBER = "6281292000029";

	document.querySelectorAll('.unit-card').forEach(card => {
		card.addEventListener('click', () => {
		const unit = JSON.parse(card.dataset.unit);

		document.getElementById('modal-detail-img').innerHTML = unit.detail_img
			.map(src => `<img src="/${src}" alt="${unit.tipe_unit}" style="width:100%;border-radius:10px;margin-bottom:8px;">`)
			.join('');

		document.getElementById('modal-title').textContent = unit.tipe_unit;
		document.getElementById('modal-luas').textContent = '📐 Luas: ' + unit.luas;
		document.getElementById('modal-desc').textContent = unit.desc;

		const waMsg = encodeURIComponent(`Halo, saya tertarik dengan unit *${unit.tipe_unit}* (${unit.luas}) di Bandung Technoplex Living. Boleh saya mendapatkan informasi lebih lanjut?`);
		document.getElementById('modal-wa-btn').href = `https://wa.me/${WA_NUMBER}?text=${waMsg}`;

		const modal = document.getElementById('unit-modal');
		modal.style.display = 'flex';
		document.body.style.overflow = 'hidden';
		});
	});

	document.getElementById('modal-close').addEventListener('click', closeModal);
	document.getElementById('unit-modal').addEventListener('click', e => {
		if (e.target === document.getElementById('unit-modal')) closeModal();
	});
	document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

	function closeModal() {
		document.getElementById('unit-modal').style.display = 'none';
		document.body.style.overflow = '';
	}
	</script>
	
</body>
</html>