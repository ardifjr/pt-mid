---
import MainLayout from '../layouts/MainLayout.astro';
import artikelDataRaw from '../data/artikel.json';
const latestArtikel = artikelDataRaw.slice(0, 3); 
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PT Multyartha Indo Daya</title>
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
	<link rel="stylesheet" href="assets/css/feather.css">
    <!-- CSS dari public -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
  <body>
	<div class="main-wrapper">
		<MainLayout title="Beranda">
		<!-- Hero Section -->
		<section class="hero-section">			
			<div class="container">
				<div class="home-banner">
					<div class="row align-items-center w-100">
						<div class="col-lg-7 col-md-10 mx-auto">
							<div class="section-search aos" data-aos="fade-up">
								<h1>PT Multyartha Indo Daya</h1>
								<p>Construction Company Services Your ultimate construction partners</p>
								<div class="search-box">
									<form action="search.html"> 
										<div class="search-input line">
											<div class="search-group-icon">
												<i class="feather-map-pin"></i>
											</div>
											<div class="form-group mb-0">
												<label>Bandung</label>
												<input type="text" class="form-control" placeholder="Indonesia">
											</div>
										</div>
										<div class="search-input">
											<div class="search-group-icon search-icon">
												<i class="feather-search"></i>
											</div>
											<div class="form-group mb-0">
												<label>Apa yang kamu cari ?</label>
												<input type="text" class="form-control" placeholder="Restorasi Gedung">
											</div>
										</div>
										<div class="search-btn">
											<button class="btn btn-primary" type="button"
												onclick="window.location.href='https://wa.me/62895701946800'">
												<i class="feather-search me-2"></i>Kontak
											</button>
										</div>
									</form>
								</div>
							</div>
						</div>
						<div class="col-lg-5">
							<div class="banner-imgs">
								<div class="banner-1 shape-1">
									<img class="img-fluid" alt="banner" src="assets/img/banner1.png">
								</div>
								<div class="banner-2 shape-3">
									<img class="img-fluid" alt="banner" src="assets/img/banner2.png">
								</div>
								<div class="banner-3 shape-3">
									<img class="img-fluid" alt="banner" src="assets/img/banner3.png">
								</div>
								<div class="banner-4 shape-2">
									<img class="img-responsive" alt="banner" src="assets/img/banner4.png">
								</div>
							</div>
						</div>
					</div>
				</div>	
			</div>
		</section>
		<!-- /Hero Section -->
		
		<!-- Feature Section -->
		<section class="feature-section">			
			<div class="container">			
				<div class="section-heading">
					<div class="row">
						<div class="col-md-6 aos" data-aos="fade-up">
							<h2>Layanan Kita</h2>
							<p>Apa yang perlu kamu temukan ?</p>
						</div>
						<div class="col-md-6 text-md-end aos" data-aos="fade-up">
							<a href="/layanan" class="btn btn-primary btn-view">Lihat Detail<i class="feather-arrow-right-circle"></i></a>
						</div>
					</div>
				</div>
				<div class="row">
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/about-icon-02.svg" alt="img">
								</span>
							</div>
							<h5>Land Surveying</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-07.svg" alt="img">
								</span>
							</div>
							<h5>Topography</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-01.svg" alt="img">
								</span>
							</div>
							<h5>Architect</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-05.svg" alt="img">
								</span>
							</div>
							<h5>Landscape</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-05.svg" alt="img">
								</span>
							</div>
							<h5>Sub Grade</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-06.svg" alt="img">
								</span>
							</div>
							<h5>Compaction</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-08.svg" alt="img">
								</span>
							</div>
							<h5>Moisture Content</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
					<div class="col-md-6 col-lg-3">
						<a href="/layanan" class="feature-box aos" data-aos="fade-up">
							<div class="feature-icon">
								<span>
									<img src="assets/img/icons/feature-icon-08.svg" alt="img">
								</span>
							</div>
							<h5>Soil Type</h5>
							<div class="feature-overlay">
								<img src="assets/img/services/service-01.jpg" alt="img">
							</div>
						</a>
					</div>
				</div>
			</div>
		</section>
		<!-- /Feature Section -->
		
		<!-- Service Section -->
		<section class="service-section">			
			<div class="container">
				<div class="section-heading">
					<div class="row">
						<div class="col-md-6 aos" data-aos="fade-up">						
							<h2></h2>
							<p></p>
						</div>
						<div class="col-md-6 text-md-end aos" data-aos="fade-up">
							<div class="owl-nav mynav"></div>
						</div>
					</div>
				</div>
			</div>
		</section>
		<!-- /Service Section -->

		<!-- Work Section -->
		<section class="work-section pt-0">		
			<div class="container">
				<div class="row  aos" data-aos="fade-up">
					<div class="col-md-12">
						<div class="offer-paths">
							<div class="offer-pathimg">
								<img src="assets/img/offer.png" alt="img">
							</div>
							<div class="offer-path-content">
								<h3>Apartement Technoplex Living Bandung</h3>
								<p>PT Multi Karya Utama Abadi, adalah developer yang mengembangkan proyek Apartemen
Bandung Technoplex Living.
Kami bekerja sama dengan Yayasan Pendidikan Telkom sebagai pemilik tanah dimana kami
diberikan hak untuk membangun, menjual apartemen, dan mengelola gedung selama 30 tahun.</p>
								<a href="/technoplexLiving" class="btn btn-primary btn-views">Detail<i class="feather-arrow-right-circle"></i></a>
							</div>
						</div>
					</div>
				</div>
			</div>	
			<div class="container">
				<div class="row">
					<div class="col-md-12 text-center">
						<div class="section-heading aos" data-aos="fade-up">
							<h2>Keunggulan Kami</h2>
							<p>Kami Selalu Memberikan Yang Terbaik</p>
						</div>
					</div>
				</div>
				<div class="row">
					<div class="col-md-4">
						<div class="work-box aos" data-aos="fade-up">
							<div class="work-icon">
								<span>
									<img src="assets/img/icons/work-icon.svg" alt="img">
								</span>
							</div>
							<h5>Layanan Konstruksi yang Lengkap</h5>
							<p>PT Multyartha Indo Daya menyediakan berbagai layanan mulai dari land surveying, arsitektur, landscape, subgrade, cut and fill, hingga pembangunan struktur dan civil works. Dengan cakupan layanan yang luas ini, perusahaan mampu menangani proyek dari tahap perencanaan hingga pembangunan secara menyeluruh.</p>
							<h4>01</h4>
						</div>						
					</div>
					<div class="col-md-4">
						<div class="work-box aos" data-aos="fade-up">
							<div class="work-icon">
								<span>
									<img src="assets/img/icons/find-icon.svg" alt="img">
								</span>
							</div>
							<h5>Didukung Tim Profesional dan Peralatan Lengkap</h5>
							<p>Perusahaan memiliki tenaga ahli seperti builder, carpenter, electrician, horticulturalist, dan irrigation specialist, serta didukung oleh berbagai alat berat konstruksi seperti crawler dozer, excavator, motor grader, vibratory compactor, dan lainnya. Hal ini memungkinkan pengerjaan proyek yang lebih efisien, presisi, dan berkualitas.</p>
							<h4>02</h4>
						</div>						
					</div>
					<div class="col-md-4">
						<div class="work-box aos" data-aos="fade-up">
							<div class="work-icon">
								<span>
									<img src="assets/img/icons/place-icon.svg" alt="img">
								</span>
							</div>
							<h5>Pengalaman Proyek yang Beragam dan Terpercaya</h5>
							<p>PT Multyartha Indo Daya telah menangani berbagai proyek konstruksi sebagai main contractor maupun sub contractor, pengalaman kami sudah melakukan pembangunan seperti rest area tol, SPBU, proyek kereta cepat Jakarta-Bandung, gedung, perumahan, hingga proyek industri.</p>
							<h4>03</h4>
						</div>						
					</div>
				</div>
			</div>
		</section>
		<!-- /Work Section -->

		
		
		<!-- Modal Artikel -->
		<style>
		#artikel-modal-overlay {
			display: none;
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.6);
			z-index: 9999;
			align-items: center;
			justify-content: center;
			padding: 20px;
		}
		#artikel-modal-overlay.active {
			display: flex;
		}
		#artikel-modal {
			background: #fff;
			border-radius: 12px;
			max-width: 720px;
			width: 100%;
			max-height: 90vh;
			overflow-y: auto;
			position: relative;
			box-shadow: 0 20px 60px rgba(0,0,0,0.3);
			animation: modalIn 0.25s ease;
		}
		@keyframes modalIn {
			from { transform: translateY(-30px); opacity: 0; }
			to   { transform: translateY(0);     opacity: 1; }
		}
		#artikel-modal .modal-img {
			width: 100%;
			max-height: 320px;
			object-fit: cover;
			border-radius: 12px 12px 0 0;
		}
		#artikel-modal .modal-body-custom {
			padding: 28px 32px 32px;
		}
		#artikel-modal .modal-category {
			display: inline-block;
			background: #0d6efd;
			color: #fff;
			font-size: 12px;
			font-weight: 600;
			padding: 4px 12px;
			border-radius: 20px;
			margin-bottom: 12px;
			letter-spacing: 0.5px;
		}
		#artikel-modal .modal-title {
			font-size: 22px;
			font-weight: 700;
			color: #1a1a2e;
			margin-bottom: 10px;
			line-height: 1.4;
		}
		#artikel-modal .modal-meta {
			font-size: 13px;
			color: #888;
			margin-bottom: 18px;
			display: flex;
			align-items: center;
			gap: 8px;
		}
		#artikel-modal .modal-desc {
			font-size: 15px;
			color: #444;
			line-height: 1.8;
		}
		#modal-close-btn {
			position: absolute;
			top: 14px;
			right: 14px;
			background: rgba(0,0,0,0.55);
			border: none;
			color: #fff;
			width: 34px;
			height: 34px;
			border-radius: 50%;
			font-size: 18px;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background 0.2s;
			z-index: 10;
		}
		#modal-close-btn:hover {
			background: rgba(0,0,0,0.8);
		}
		</style>

		<div id="artikel-modal-overlay">
		<div id="artikel-modal">
			<button id="modal-close-btn" aria-label="Tutup">&times;</button>
			<img id="modal-img" class="modal-img" src="" alt="Artikel" />
			<div class="modal-body-custom">
			<span id="modal-category" class="modal-category"></span>
			<h2 id="modal-title" class="modal-title"></h2>
			<div class="modal-meta">
				<i class="fa-regular fa-calendar"></i>
				<span id="modal-date"></span>
			</div>
			<p id="modal-desc" class="modal-desc"></p>
			</div>
		</div>
		</div>

		<!-- Blog Section -->
		<section class="blog-section">
		<div class="container">
			<div class="row">
			<div class="col-md-12 text-center aos" data-aos="fade-up">
				<div class="section-heading">
				<h2>Artikel Terbaru</h2>
				<p>Kami Menyediakan Artikel Menarik</p>
				</div>
			</div>
			</div>
			<div class="row justify-content-between">

			{latestArtikel.map((post) => (
				<div class="col-lg-4 col-md-6 d-flex">
				<div class="blog flex-fill aos" data-aos="fade-up">
					<div class="blog-image">
					<!-- Image → buka modal -->
					<a href="#" class="open-modal-link" data-id={post.id}>
						<img class="img-fluid" src={post.image} alt="Post Image" />
					</a>
					</div>
					<div class="blog-content">
					<ul class="blog-item">
						<li><i class="feather-calendar"></i>{post.date}</li>
						<li>
						<div class="post-author">
							<a href="#"><i class="feather-user"></i><span>Admin</span></a>
						</div>
						</li>
					</ul>
					<!-- Title → buka modal -->
					<h3 class="blog-title">
						<a href="#" class="open-modal-link" data-id={post.id}>{post.title}</a>
					</h3>
					</div>
				</div>
				</div>
			))}

			<div class="col-md-12 text-md-end aos" data-aos="fade-up">
				<a href="/artikel" class="btn btn-primary btn-view">
				Lihat Semua<i class="feather-arrow-right-circle"></i>
				</a>
			</div>
			</div>
		</div>
		</section>
		<!-- /Blog Section -->
				
		
		<!-- Client Section -->
		<section class="client-section">
		<div class="container">
			<div class="row">
			<div class="col-md-12 text-center">
				<div class="section-heading aos" data-aos="fade-up">
				<h2>Apa yang klien kami katakan</h2>
				<p>Kepercayaan dan kepuasan klien adalah prioritas kami</p>
				</div>
			</div>
			</div>

			<div class="row">
			<div class="col-md-12">
				<div class="testimonial-slider-wrapper">
				<div class="testimonial-track" id="testimonialTrack">

					<div class="client-widget">
					<div class="client-content">
						<div class="rating">
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						</div>
						<p>
						PT Multyartha Indo Daya memberikan hasil pekerjaan yang sangat memuaskan. 
						Tim mereka profesional, pengerjaan rapi, dan proyek selesai tepat waktu 
						sesuai dengan perencanaan yang telah disepakati.
						</p>
						<h5>Budi Santoso</h5>
						<h6>Project Manager</h6>
					</div>
					</div>

					<div class="client-widget">
					<div class="client-content">
						<div class="rating">
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						</div>
						<p>
						Kami sangat terbantu dengan pelayanan yang diberikan. 
						Komunikasi dengan tim sangat baik dan setiap detail pekerjaan 
						diperhatikan dengan serius sehingga hasilnya sesuai harapan.
						</p>
						<h5>Andi Pratama</h5>
						<h6>Site Supervisor</h6>
					</div>
					</div>

					<div class="client-widget">
					<div class="client-content">
						<div class="rating">
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						<i class="fas fa-star filled"></i>
						</div>
						<p>
						Pengalaman bekerja sama dengan PT Multyartha Indo Daya sangat positif. 
						Mereka memiliki tim yang berpengalaman dan mampu menyelesaikan pekerjaan 
						konstruksi dengan kualitas yang baik dan profesional.
						</p>
						<h5>Rizky Hidayat</h5>
						<h6>Business Owner</h6>
					</div>
					</div>

				</div>

				<button class="testi-prev" id="testiPrev">
					<i class="fa-solid fa-angle-left"></i>
				</button>
				<button class="testi-next" id="testiNext">
					<i class="fa-solid fa-angle-right"></i>
				</button>

				</div>
			</div>
			</div>
		</div>
		</section>

		<style>
		.testimonial-slider-wrapper {
			position: relative;
			overflow: hidden;
			padding: 0 50px;
		}

		.testimonial-track {
			display: flex;
			transition: transform 0.4s ease;
			gap: 24px;
		}

		.client-widget {
			flex: 0 0 calc(50% - 12px);
			min-width: calc(50% - 12px);
			background: #fff;
			border-radius: 12px;
			padding: 24px;
			box-shadow: 0 4px 20px rgba(0,0,0,0.08);
			display: flex;
			gap: 16px;
			align-items: flex-start;
			box-sizing: border-box;
		}

		.client-img {
			flex-shrink: 0;
		}

		.client-img img {
			width: 60px;
			height: 60px;
			border-radius: 50%;
			object-fit: cover;
		}

		.client-content p {
			font-size: 14px;
			color: #666;
			margin: 8px 0;
			line-height: 1.6;
		}

		.client-content h5 {
			font-size: 15px;
			font-weight: 600;
			margin: 0 0 2px;
		}

		.client-content h6 {
			font-size: 13px;
			color: #888;
			margin: 0;
		}

		.rating i {
			color: #ffc107;
			font-size: 13px;
		}

		.testi-prev,
		.testi-next {
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			background: #fff;
			border: 1px solid #ddd;
			border-radius: 50%;
			width: 38px;
			height: 38px;
			display: flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			z-index: 10;
			transition: background 0.2s, color 0.2s;
			font-size: 14px;
		}

		.testi-prev:hover,
		.testi-next:hover {
			background: #0d6efd;
			color: #fff;
			border-color: #0d6efd;
		}

		.testi-prev { left: 0; }
		.testi-next { right: 0; }

		@media (max-width: 767px) {
			.client-widget {
			flex: 0 0 100%;
			min-width: 100%;
			}
			.testimonial-slider-wrapper {
			padding: 0 44px;
			}
		}
		</style>

		<script>
		const track = document.getElementById('testimonialTrack');
		const prevBtn = document.getElementById('testiPrev');
		const nextBtn = document.getElementById('testiNext');

		function getVisible() {
			return window.innerWidth <= 767 ? 1 : 2;
		}

		let current = 0;

		function getTotal() {
			return track.children.length;
		}

		function updateSlider() {
			const visible = getVisible();
			const total = getTotal();
			// Clamp current index
			const max = total - visible;
			if (current > max) current = 0;
			if (current < 0) current = max;

			const cardWidth = track.children[0].offsetWidth;
			const gap = 24;
			track.style.transform = `translateX(-${current * (cardWidth + gap)}px)`;
		}

		prevBtn.addEventListener('click', () => {
			const visible = getVisible();
			const max = getTotal() - visible;
			current = current <= 0 ? max : current - 1;
			updateSlider();
		});

		nextBtn.addEventListener('click', () => {
			const visible = getVisible();
			const max = getTotal() - visible;
			current = current >= max ? 0 : current + 1;
			updateSlider();
		});

		window.addEventListener('resize', updateSlider);
		updateSlider();
		</script>
