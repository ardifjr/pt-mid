			display: flex;
			align-items: center;
			width: max-content;
			will-change: transform;
		}
		</style>

		<script>
		(function () {
			const wrapper = document.querySelector('.partners-track-wrapper');
			const track   = document.getElementById('partnersTrack');

			const BASE_SPEED = 0.6;      // px per frame (normal speed)
			const MAX_BOOST  = 8;        // max extra speed from drag
			const FRICTION   = 0.92;     // momentum decay per frame

			let pos       = 0;
			let velocity  = BASE_SPEED;  // current speed (px/frame, negative = left)
			let halfWidth = 0;

			let isDragging = false;
			let lastX      = 0;
			let dragVel    = 0;

			function init() {
				halfWidth = track.scrollWidth / 2;
				requestAnimationFrame(tick);
			}

			function tick() {
				if (!isDragging) {
					// Gradually return velocity toward BASE_SPEED
					if (Math.abs(velocity) > BASE_SPEED) {
						velocity *= FRICTION;
						if (Math.abs(velocity) < BASE_SPEED) velocity = BASE_SPEED;
					} else {
						velocity = BASE_SPEED;
					}
					pos -= velocity;
				}

				// Seamless loop
				if (pos <= -halfWidth) pos += halfWidth;
				if (pos > 0)           pos -= halfWidth;

				track.style.transform = `translateX(${pos}px)`;
				requestAnimationFrame(tick);
			}

			// --- Drag ---
			wrapper.addEventListener('mousedown', onDown);
			wrapper.addEventListener('touchstart', onDown, { passive: true });
			window.addEventListener('mousemove', onMove);
			window.addEventListener('touchmove', onMove, { passive: false });
			window.addEventListener('mouseup', onUp);
			window.addEventListener('touchend', onUp);

			function getX(e) {
				return e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
			}

			function onDown(e) {
				isDragging = true;
				lastX      = getX(e);
				dragVel    = 0;
			}

			function onMove(e) {
				if (!isDragging) return;
				if (e.type === 'touchmove') e.preventDefault();
				const x   = getX(e);
				const dx  = x - lastX;
				dragVel   = dx;
				pos      += dx;
				lastX     = x;
			}

			function onUp() {
				if (!isDragging) return;
				isDragging = false;
				// Convert drag momentum to velocity (invert: drag right = slow down, drag left = speed up)
				const boost = -dragVel;
				velocity = Math.min(BASE_SPEED + MAX_BOOST, Math.max(-MAX_BOOST, BASE_SPEED + boost));
			}

			// Wait for images to load so scrollWidth is accurate
			window.addEventListener('load', init);
			// Fallback
			setTimeout(init, 300);
		})();
		</script>

