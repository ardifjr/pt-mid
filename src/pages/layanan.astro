---
import MainLayout from '../layouts/MainLayout.astro';
import servicesData from '../data/service.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PT Multyartha Indo Daya</title>
	<link rel="stylesheet" href="assets/css/feather.css">
    <!-- CSS dari public -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
  </head>
 <body>

	
	<div class="main-wrapper">
	<MainLayout title="Layanan">
		
		<!-- Breadcrumb -->
		<div class="breadcrumb-bar">
			<div class="container">
				<div class="row">
					<div class="col-md-12">
						<h2 class="breadcrumb-title mb-0">Layanan</h2>
					</div>
				</div>
			</div>
		</div>
		<!-- /Breadcrumb -->	
		
		<!-- Content -->
		<div class="content">
			<div class="container">

				{servicesData.map((service, index) => {
					const points = service.point.split(',');
					const half = Math.ceil(points.length / 2);
					const pointsLeft = points.slice(0, half);
					const pointsRight = points.slice(half);

					return (
						<div class={`row align-items-center ${index > 0 ? 'mt-4' : ''}`}>
							<div class="col-md-5">
								<div class="provider-img">
									<img src={service.img} class="img-fluid" alt={service.service_name} />
								</div>
							</div>
							<div class="col-md-7">
								<div class="provider-info">
									<h2>{service.service_name}</h2>
									<p>{service.paragraf}</p>
									<div class="row">
										<div class="col-lg-12">
											<div class="provider-details">
												<h5>{service.desc_name}</h5>
												<p>{service.desc}</p>
												<div class="row">
													<div class="col-md-6">
														<ul>
															{pointsLeft.map((point) => (
																<li>{point.trim()}</li>
															))}
														</ul>
													</div>
													<div class="col-md-6">
														<ul class="mb-0">
															{pointsRight.map((point) => (
																<li>{point.trim()}</li>
															))}
														</ul>
													</div>
												</div>
											</div>
										</div>
									</div>
									<div class="col-md-12 mt-4">
										<button class="btn btn-primary" type="submit" onclick="window.location.href='https://wa.me/62895701946800'">Konsultasi<i class="feather-arrow-right-circle ms-2"></i></button>
									</div>
								</div>
							</div>
						</div>
					);
				})}

			</div>			
		</div>
		<!-- /Content -->
		
		<!-- Cursor -->
		<div class="mouse-cursor cursor-outer"></div>
		<div class="mouse-cursor cursor-inner"></div>
		<!-- /Cursor -->
		
	</MainLayout>
	</div>
	
	<!-- jQuery -->
	<script src="/assets/js/jquery-3.6.1.min.js" is:inline></script>

	<!-- Bootstrap Core JS -->
	<script src="/assets/js/bootstrap.bundle.min.js" is:inline></script>

	<!-- Fearther JS -->
	<script src="/assets/js/feather.min.js" is:inline></script>
		
	<!-- Owl Carousel JS -->
	<script src="/assets/js/owl.carousel.min.js" is:inline></script>

	<!-- select JS -->
	<script src="/assets/plugins/select2/js/select2.min.js" is:inline></script>

	<!-- Custom JS -->
	<script src="/assets/js/script.js" is:inline></script>	
	
</body>
</html>
